{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "XML Viewer BR",
  "version": "1.0.1",
  "identifier": "com.xmlviewer.br",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "XML Viewer BR",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hernantk/xml-viewer-br/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBQzFDMkMwNzcyNTFFMTAKUldRUUhpVjN3TUxCYXBGdE1tVG5CaGFBdUVBTXhXNmdQR3dnbmFDK1VSa0JaSVVSUjhsWVBLUlcK",
      "windows": {
        "installerArgs": ["/SILENT"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["xml"],
        "mimeType": "application/xml",
        "name": "Documento XML"
      }
    ],
    "shortDescription": "Visualizador de XML fiscal brasileiro",
    "longDescription": "Visualizador de documentos fiscais eletrônicos brasileiros: NF-e, CT-e e NFS-e. Permite visualizar, imprimir e exportar DANFE, DACTE e NFS-e em PDF.",
    "copyright": "© 2026 XML Viewer BR",
    "category": "Utility",
    "windows": {
      "nsis": {
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false
      }
    }
  }
}
